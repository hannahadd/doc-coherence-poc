# ── Fournisseur LLM ──────────────────────────────────────────────────────────
# Sur Mac (dev) : LLM_PROVIDER=mistral
# Sur PC MBDA   : LLM_PROVIDER=internal
LLM_PROVIDER=mistral

# ── Mistral API publique ──────────────────────────────────────────────────────
# Clé API Mistral — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ── Chatbot interne MBDA ──────────────────────────────────────────────────────
INTERNAL_LLM_URL=https://nom/api/chat/completions
INTERNAL_LLM_TOKEN=
INTERNAL_LLM_MODEL=Mistral-Small-3.1
