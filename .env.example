# ── Configuration LLM ────────────────────────────────────────────────────────
# Seul LLM_TOKEN est obligatoire.
# Renseignez votre token d'entreprise — les autres variables ont déjà les bonnes valeurs.

LLM_TOKEN=

# Endpoint OpenAI-compatible du chatbot interne
LLM_URL=https://votre-endpoint-interne/api/chat/completions

# Modèle — Mistral-Small-3.1 par défaut, adaptez si votre déploiement utilise un autre nom
LLM_MODEL=Mistral-Small-3.1

# ── Exemples alternatifs (dev / test) ────────────────────────────────────────
# Gemini gratuit :
# LLM_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# LLM_MODEL=gemini-2.0-flash

# OpenAI :
# LLM_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o-mini
